---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav class="nav-container">
		<h2><a href="/" class="site-logo">曾智凱 <span>Kai</span></a></h2>
		<div class="internal-links">
			<HeaderLink href="/">首頁 (Home)</HeaderLink>
			<HeaderLink href="/blog">學習日誌 (Journal)</HeaderLink>
			<HeaderLink href="/tasks">任務 (Tasks)</HeaderLink>
			<HeaderLink href="/weekly">週報 (Weekly)</HeaderLink>
			<HeaderLink href="/literature">文獻導航 (Literature)</HeaderLink>
			<HeaderLink href="/about">關於我 (About)</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 20px;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(10px); /* 讓導覽列有一點毛玻璃的現代感 */
		border-bottom: 1px solid #eaeaea;
		position: sticky; /* 讓導覽列固定在頂部 */
		top: 0;
		z-index: 1000;
	}
	.nav-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1000px;
		margin: 0 auto;
		padding: 16px 0;
	}
	h2 {
		margin: 0;
		font-size: 1.3rem;
	}
	.site-logo {
		font-weight: 800;
		color: #111;
		text-decoration: none;
		letter-spacing: -0.02em;
	}
	.site-logo span {
		color: #888;
		font-weight: 600;
		margin-left: 4px;
	}
	.internal-links {
		display: flex;
		gap: 24px;
	}
	/* 覆寫預設的 HeaderLink 樣式 */
	.internal-links :global(a) {
		text-decoration: none;
		color: #666;
		font-weight: 500;
		font-size: 0.95rem;
		padding: 6px 0;
		transition: color 0.2s ease;
		border-bottom: 2px solid transparent;
	}
	.internal-links :global(a:hover) {
		color: #111;
	}
	.internal-links :global(a.active) {
		color: #111;
		font-weight: 700;
		border-bottom-color: #111; /* 當前頁面會有底線提示 */
	}
	@media (max-width: 720px) {
		.nav-container {
			flex-direction: column;
			gap: 16px;
		}
		.internal-links {
			gap: 16px;
			flex-wrap: wrap;
			justify-content: center;
		}
	}
</style>
