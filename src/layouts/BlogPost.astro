---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category = '未分類',
	tags = [],
} = Astro.props;

const hasMetadata = Boolean(category || tags.length > 0);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} />

		<style>
			main {
				width: 100%;
				margin: 0 auto;
			}

			.hero-image {
				width: 100%;
				max-width: 900px;
				margin: 0 auto 2em;
			}

			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 16px;
				box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04);
				max-width: 100%;
				height: auto;
			}

			.prose {
				width: 100%;
				max-width: 720px;
				margin: auto;
				padding: 2em 1em;
				color: #111;
				line-height: 1.8;
				font-size: 1.1rem;
			}

			.title {
				margin-bottom: 2.5em;
				text-align: center;
				line-height: 1.2;
			}

			.title h1 {
				margin: 0.2em 0 0.5em;
				font-size: 3rem;
				font-weight: 800;
				letter-spacing: -0.02em;
			}

			.date {
				margin-bottom: 1em;
				color: #666;
				font-size: 0.95rem;
				letter-spacing: 0.05em;
			}

			.last-updated-on {
				font-style: normal;
				margin-top: 0.5em;
			}

			.post-meta {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 8px;
				margin: 1em 0 1.5em;
			}

			.category,
			.tag {
				display: inline-flex;
				align-items: center;
				border-radius: 999px;
				font-size: 0.82rem;
				line-height: 1;
				padding: 7px 10px;
			}

			.category {
				background: #111;
				color: #fff;
			}

			.tag {
				background: #f3f4f6;
				color: #444;
			}

			hr {
				border: none;
				border-top: 1px solid #eaeaea;
				margin: 2em 0;
			}

			@media (max-width: 720px) {
				.title h1 {
					font-size: 2.25rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<article>
				<div class="hero-image">
					{
						heroImage && (
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt={title}
							/>
						)
					}
				</div>

				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />

							{
								updatedDate && (
									<div class="last-updated-on">
										最後更新於
										{' '}
										<FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>

						<h1>{title}</h1>

						{
							hasMetadata && (
								<div class="post-meta">
									<span class="category">
										{category}
									</span>

									{
										tags.map((tag) => (
											<span class="tag">{tag}</span>
										))
									}
								</div>
							)
						}

						<hr />
					</div>

					<slot />
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>
