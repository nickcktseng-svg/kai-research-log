---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1000px;
				margin: 0 auto;
				padding: 40px 20px;
				font-family: system-ui, -apple-system, sans-serif;
			}
			.hero {
				padding: 80px 0 60px 0;
			}
			.hero h1 {
				font-size: 5rem;
				font-weight: 800;
				line-height: 1.05;
				margin-bottom: 0.3em;
				letter-spacing: -0.03em;
				color: #111;
			}
			.hero h1 span {
				display: block;
				font-size: 4rem;
				color: #666;
				margin-top: 5px;
			}
			.intro-text {
				font-size: 1.2rem;
				color: #555;
				line-height: 1.8;
				max-width: 700px;
				margin-top: 30px;
			}
			.quick-links {
				display: flex;
				gap: 16px;
				margin-top: 32px;
				flex-wrap: wrap;
			}
			.link-btn {
				display: inline-flex;
				align-items: center;
				padding: 10px 20px;
				background-color: #f5f5f5;
				color: #111;
				text-decoration: none;
				border-radius: 30px;
				font-size: 0.95rem;
				font-weight: 600;
				border: 1px solid #eaeaea;
				transition: all 0.2s ease;
			}
			.link-btn:hover {
				background-color: #111;
				color: #fff;
				transform: translateY(-2px);
			}
			.feature-cards {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 24px;
				margin-top: 60px;
				margin-bottom: 40px;
			}
			.card {
				background: #ffffff;
				border-radius: 16px;
				padding: 32px;
				box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
				border: 1px solid #f5f5f5;
				text-decoration: none;
				color: inherit;
				transition:
				transform 0.2s ease,
				box-shadow 0.2s ease;
			}
			.card:hover {
				transform: translateY(-4px);
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
			}
			.card h3 {
				margin-top: 0;
				font-size: 1.4rem;
				color: #111;
				margin-bottom: 16px;
				font-weight: 700;
			}
			.card p {
				color: #666;
				line-height: 1.6;
				margin-bottom: 0;
				font-size: 0.95rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>曾智凱 <span>Kai</span></h1>
				<p class="intro-text">
				這是一個記錄計算化學研究、模型建構與研究工具開發的個人研究空間。<br /><br />
				目前主要整理 VASP、DFT、HPC、ASE、Slab 模型建構、文獻搜尋，以及 AI 輔助研究過程中的實作與踩坑經驗。
					</p>
				<div class="quick-links">
					<a href="https://gemini.google.com/" target="_blank" class="link-btn">✨ Gemini</a>
					<a href="https://chatgpt.com/" target="_blank" class="link-btn">🤖 ChatGPT</a>
					<a href="https://claude.ai/" target="_blank" class="link-btn">🧠 Claude</a>
					<a href="https://www.perplexity.ai/" target="_blank" class="link-btn">🔍 Perplexity</a>
					<a
					href="https://github.com/nickcktseng-svg"
					target="_blank"
					rel="noopener noreferrer"
					class="link-btn"
					>
					🐙 GitHub
					</a>
					<a href="https://dash.cloudflare.com/" target="_blank" class="link-btn">☁️ Cloudflare</a>
				</div>
			</section>

			<section class="feature-cards">
	<a href="/blog" class="card">
		<h3>📝 研究日誌</h3>
		<p>
			記錄實驗室研究、計算環境設定、程式開發、問題排除與每個階段的研究反思。
		</p>
	</a>

	<a href="/literature" class="card">
		<h3>🔍 文獻導航</h3>
		<p>
			透過 OpenAlex 搜尋學術文獻，支援年份、引用數、關聯度與 Open Access 篩選。
		</p>
	</a>

	<a href="/about" class="card">
		<h3>🧪 研究與工具</h3>
		<p>
			整理 VASP、DFT、HPC、ASE、Slab 模型建構，以及 AI 輔助研究工具的學習過程。
		</p>
	</a>
</section>
		</main>
		<Footer />
	</body>
</html>
