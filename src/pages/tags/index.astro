---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = await getCollection('blog', ({ data }) => !data.draft);

const tagCounts = new Map<string, number>();

posts.forEach((post) => {
	post.data.tags.forEach((tag) => {
		tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
	});
});

const tags = Array.from(tagCounts.entries())
	.map(([name, count]) => ({ name, count }))
	.sort((a, b) => a.name.localeCompare(b.name, 'zh-Hant'));
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`文章標籤 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />

		<style>
			main {
				width: 100%;
				max-width: 1000px;
				margin: 0 auto;
				padding: 40px 20px;
			}

			.page-title {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 10px;
				letter-spacing: -0.02em;
				color: #111;
			}

			.page-desc {
				color: #666;
				font-size: 1.1rem;
				margin-bottom: 40px;
			}

			.tag-list {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.tag-link {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 10px 14px;
				border-radius: 999px;
				background: #f3f4f6;
				color: #333;
				text-decoration: none;
				transition:
					background-color 0.2s ease,
					transform 0.2s ease;
			}

			.tag-link:hover {
				background: #e5e7eb;
				transform: translateY(-2px);
			}

			.tag-count {
				color: #777;
				font-size: 0.85rem;
			}

			.back-link {
				display: inline-block;
				margin-top: 40px;
				color: #555;
				text-decoration: none;
			}

			.back-link:hover {
				color: #111;
				text-decoration: underline;
			}

			@media (max-width: 720px) {
				.page-title {
					font-size: 2.5rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<h1 class="page-title">文章標籤</h1>
			<p class="page-desc">依照關鍵字瀏覽研究日誌。</p>

			<ul class="tag-list">
				{
					tags.map((tag) => (
						<li>
							<a
								href={`/tags/${encodeURIComponent(tag.name)}/`}
								class="tag-link"
							>
								<span>{tag.name}</span>
								<span class="tag-count">{tag.count}</span>
							</a>
						</li>
					))
				}
			</ul>

			<a href="/blog" class="back-link">← 回到學習日誌</a>
		</main>

		<Footer />
	</body>
</html>
