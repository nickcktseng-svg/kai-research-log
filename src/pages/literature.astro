---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`文獻導航 | ${SITE_TITLE}`} description="搜尋與整理學術文獻" />
		<style>
			main {
				width: 100%;
				max-width: 1000px;
				margin: 0 auto;
				padding: 40px 20px;
			}
			.page-title {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 10px;
				letter-spacing: -0.02em;
				color: #111;
			}
			.page-desc {
				color: #666;
				font-size: 1.1rem;
				margin-bottom: 40px;
				max-width: 600px;
				line-height: 1.6;
			}
			/* 搜尋區塊 */
			.search-box {
				display: flex;
				gap: 12px;
				margin-bottom: 20px;
				flex-wrap: wrap;
				align-items: center;
			}
			.search-input {
				flex: 1;
				min-width: 250px;
				padding: 16px 24px;
				font-size: 1.1rem;
				border: 1px solid #eaeaea;
				border-radius: 30px;
				background-color: #fcfcfc;
				transition: all 0.2s ease;
			}
			.search-input:focus {
				outline: none;
				border-color: #111;
				background-color: #fff;
			}
			.sort-select {
				padding: 16px 20px;
				font-size: 1rem;
				border: 1px solid #eaeaea;
				border-radius: 30px;
				background-color: #fcfcfc;
				color: #111;
				cursor: pointer;
				outline: none;
			}
			.search-btn {
				padding: 16px 32px;
				font-size: 1.1rem;
				font-weight: 600;
				color: #fff;
				background-color: #111;
				border: none;
				border-radius: 30px;
				cursor: pointer;
				transition: transform 0.2s ease, background-color 0.2s ease;
			}
			.search-btn:hover {
				background-color: #333;
				transform: translateY(-2px);
			}
			/* OA 開關 */
			.oa-toggle {
				display: flex;
				align-items: center;
				gap: 8px;
				font-size: 0.95rem;
				color: #555;
				cursor: pointer;
				margin-bottom: 30px;
				font-weight: 600;
			}
			.oa-toggle input {
				width: 18px;
				height: 18px;
				cursor: pointer;
			}
			/* 狀態提示 */
			#statusMsg {
				margin-bottom: 30px;
				color: #666;
				font-weight: 600;
			}
			/* 文獻卡片 */
			.paper-list {
				display: flex;
				flex-direction: column;
				gap: 24px;
			}
			.paper-card {
				background: #fdfdfd;
				border: 1px solid #eaeaea;
				border-radius: 20px;
				padding: 32px;
				position: relative;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.paper-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06);
			}
			.card-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 20px;
				margin-bottom: 20px;
			}
			.card-meta-top { flex: 1; }
			.stars {
				display: block;
				font-size: 0.9rem;
				font-weight: 700;
				color: #555;
				margin-bottom: 8px;
			}
			.paper-title {
				font-size: 1.5rem;
				margin: 0 0 12px 0;
				color: #111;
				line-height: 1.3;
				font-weight: 800;
			}
			.paper-subtitle {
				font-size: 0.95rem;
				color: #555;
				margin: 0;
				line-height: 1.6;
			}
			.oa-badge {
				display: inline-block;
				background: #ecfdf5;
				color: #059669;
				padding: 2px 8px;
				border-radius: 12px;
				font-size: 0.8rem;
				font-weight: 700;
				margin-left: 8px;
				vertical-align: middle;
			}
			/* 分數徽章 */
			.score-badge {
				background: #111;
				color: #fff;
				border-radius: 16px;
				padding: 12px 16px;
				text-align: center;
				min-width: 70px;
			}
			.score-number {
				display: block;
				font-size: 1.6rem;
				font-weight: 800;
				line-height: 1;
				margin-bottom: 4px;
			}
			.score-label {
				display: block;
				font-size: 0.75rem;
				opacity: 0.8;
			}
			/* 摘要與推薦 */
			.paper-abstract {
				font-size: 1rem;
				color: #444;
				line-height: 1.7;
				margin-bottom: 20px;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.recommend-box { margin-bottom: 24px; }
			.recommend-box h4 {
				margin: 0 0 10px 0;
				font-size: 1rem;
				color: #111;
				font-weight: 700;
			}
			.recommend-box ul {
				margin: 0;
				padding-left: 20px;
				color: #555;
				font-size: 0.95rem;
				line-height: 1.6;
			}
			/* 底部操作按鈕 */
			.action-btns {
				display: flex;
				gap: 12px;
				flex-wrap: wrap;
			}
			.btn-analyze, .btn-copy {
				background: #111;
				color: #fff;
				border: none;
				padding: 10px 24px;
				border-radius: 20px;
				font-weight: 600;
				cursor: pointer;
				text-decoration: none;
				transition: background 0.2s;
			}
			.btn-copy { background: #eab308; color: #111; }
			.btn-copy:hover { background: #ca8a04; }
			.btn-analyze:hover { background: #333; }
			.btn-open {
				background: #f5f5f5;
				color: #111;
				border: 1px solid #ddd;
				padding: 10px 24px;
				border-radius: 20px;
				font-weight: 600;
				cursor: pointer;
				text-decoration: none;
			}
			.btn-open:hover { background: #eaeaea; }
			/* 載入更多按鈕 */
			.load-more-container {
				text-align: center;
				margin-top: 40px;
			}
			#loadMoreBtn {
				background-color: #f5f5f5;
				color: #111;
				border: 1px solid #ddd;
				display: none; /* 預設隱藏 */
			}
			#loadMoreBtn:hover { background-color: #eaeaea; }

			@media (max-width: 720px) {
				.search-box { flex-direction: column; align-items: stretch; }
				.card-header { flex-direction: column-reverse; }
				.score-badge { align-self: flex-start; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">文獻導航系統</h1>
			<p class="page-desc">輸入研究主題（建議使用英文），系統將透過 OpenAlex 資料庫搜尋文獻，並依照指定的條件進行排序與分析。</p>

			<div class="search-box">
				<input type="text" id="paperSearchInput" class="search-input" placeholder="例如: organic synthesis, complexometric titration..." />
				<select id="sortSelect" class="sort-select">
					<option value="relevance_score:desc">依照關聯度排序</option>
					<option value="cited_by_count:desc">依照引用次數排序</option>
					<option value="publication_year:desc">依照年份排序 (新至舊)</option>
				</select>
				<button id="searchBtn" class="search-btn">搜尋論文</button>
			</div>
			
			<label class="oa-toggle">
				<input type="checkbox" id="oaCheckbox" />
				<span>🟢 只顯示可免費下載的公開文獻 (Open Access)</span>
			</label>

			<div id="statusMsg"></div>
			<div id="paperResults" class="paper-list"></div>
			
			<div class="load-more-container">
				<button id="loadMoreBtn" class="search-btn">載入更多文獻 ↓</button>
			</div>
		</main>
		<Footer />

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const searchInput = document.getElementById('paperSearchInput');
				const sortSelect = document.getElementById('sortSelect');
				const oaCheckbox = document.getElementById('oaCheckbox');
				const searchBtn = document.getElementById('searchBtn');
				const loadMoreBtn = document.getElementById('loadMoreBtn');
				const statusMsg = document.getElementById('statusMsg');
				const resultsContainer = document.getElementById('paperResults');

				let currentPage = 1;
				let currentQuery = '';

				function reconstructAbstract(invertedIndex) {
					if (!invertedIndex) return '此篇文獻未提供摘要資料...';
					const words = [];
					for (const [word, positions] of Object.entries(invertedIndex)) {
						// @ts-ignore
						positions.forEach(pos => { words[pos] = word; });
					}
					return words.join(' ') + '...';
				}

				function generateRecommendations(paper, index) {
					let reasons = [];
					// @ts-ignore
					if (index < 3 && sortSelect.value.includes('relevance')) reasons.push('主題高度相關');
					if (paper.publication_year <= 2018) reasons.push('較早期文獻，可作背景補充');
					if (paper.publication_year >= 2024) reasons.push('最新發表研究，掌握前沿動態');
					if (paper.cited_by_count > 500) reasons.push('高引用文獻，可能是領域代表作');
					if (paper.open_access?.is_oa) reasons.push('此為 Open Access 文獻，可直接免費取得全文');
					if (reasons.length === 0) reasons.push('符合當前搜尋條件之參考文獻');
					return reasons.map(r => `<li>${r}</li>`).join('');
				}

				function calculateDisplayScore(paper, index) {
					let baseScore = 95 - (index * 1.5); 
					if (paper.cited_by_count > 1000) baseScore += 5;
					return Math.min(100, Math.max(60, Math.round(baseScore)));
				}

				// 產生標準引用格式 (APA Style 簡化版)
				function generateCitation(paper) {
					let authors = 'Unknown Author';
					if (paper.authorships && paper.authorships.length > 0) {
						authors = paper.authorships.map((a:any) => a.author.display_name).join(', ');
					}
					const year = paper.publication_year || 'n.d.';
					const title = paper.title || 'Untitled';
					const journal = paper.primary_location?.source?.display_name || '';
					const doi = paper.doi ? ` ${paper.doi}` : '';
					return `${authors} (${year}). ${title}. ${journal ? journal + '.' : ''}${doi}`;
				}

				async function searchPapers(isLoadMore = false) {
					// @ts-ignore
					const query = searchInput.value.trim();
					// @ts-ignore
					const sortBy = sortSelect.value;
					// @ts-ignore
					const isOaOnly = oaCheckbox.checked;

					if (!query) return;

					if (!isLoadMore) {
						currentPage = 1;
						currentQuery = query;
						if(resultsContainer) resultsContainer.innerHTML = '';
						if(loadMoreBtn) loadMoreBtn.style.display = 'none';
					} else {
						currentPage++;
					}

					if(statusMsg) statusMsg.textContent = isLoadMore ? '載入中，請稍候...' : '搜尋中，請稍候...';

					try {
						let url = `https://api.openalex.org/works?search=${encodeURIComponent(currentQuery)}&per-page=10&page=${currentPage}&sort=${sortBy}`;
						if (isOaOnly) {
							url += '&filter=is_oa:true';
						}

						const response = await fetch(url);
						const data = await response.json();

						if (data.results && data.results.length > 0) {
							if(statusMsg) statusMsg.textContent = `搜尋完成！目前顯示 ${document.querySelectorAll('.paper-card').length + data.results.length} 筆結果。`;
							
							data.results.forEach((paper: any, index: number) => {
								const card = document.createElement('div');
								card.className = 'paper-card';
								
								const title = paper.title || '無標題';
								const link = paper.doi || paper.id || '#';
								const year = paper.publication_year || '未知年份';
								const citedBy = paper.cited_by_count || 0;
								const journal = paper.primary_location?.source?.display_name || 'Unknown Journal';
								const isOa = paper.open_access?.is_oa;
								
								let authors = '未知作者';
								if (paper.authorships && paper.authorships.length > 0) {
									authors = paper.authorships.slice(0, 3).map((a:any) => a.author.display_name).join(', ');
									if (paper.authorships.length > 3) authors += ' 等人';
								}

								const abstractText = reconstructAbstract(paper.abstract_inverted_index);
								const recommendations = generateRecommendations(paper, index);
								
								// 解決分頁後分數遞減的問題 (讓後面頁數的分數接續算)
								const overallIndex = ((currentPage - 1) * 10) + index;
								const displayScore = calculateDisplayScore(paper, overallIndex);
								const starDisplay = overallIndex < 3 ? '★★★★★ 優先閱讀' : '★★★★☆ 推薦參考';
								
								const citationText = generateCitation(paper);
								const encodedCitation = encodeURIComponent(citationText);

								card.innerHTML = `
									<div class="card-header">
										<div class="card-meta-top">
											<span class="stars">${starDisplay}</span>
											<h2 class="paper-title">${title} ${isOa ? '<span class="oa-badge">Open Access</span>' : ''}</h2>
											<p class="paper-subtitle">${year} · ${journal} · Citations: ${citedBy} <br><br> ${authors}</p>
										</div>
										<div class="score-badge">
											<span class="score-number">${displayScore}</span>
											<span class="score-label">Score</span>
										</div>
									</div>
									
									<p class="paper-abstract">${abstractText}</p>
									
									<div class="recommend-box">
										<h4>推薦原因</h4>
										<ul>${recommendations}</ul>
									</div>

									<div class="action-btns">
										<button class="btn-copy" data-citation="${encodedCitation}">📋 Copy Citation</button>
										<a href="#" class="btn-analyze" onclick="alert('本地端 AI 分析功能即將上線！')">Analyze</a>
										<a href="${link}" target="_blank" class="btn-open">Open Paper</a>
									</div>
								`;
								if(resultsContainer) resultsContainer.appendChild(card);
							});

							// 如果回傳資料滿 10 筆，代表可能還有下一頁，顯示載入更多按鈕
							if (data.results.length === 10) {
								if(loadMoreBtn) loadMoreBtn.style.display = 'inline-block';
							} else {
								if(loadMoreBtn) loadMoreBtn.style.display = 'none';
							}

						} else {
							if (!isLoadMore && statusMsg) statusMsg.textContent = '找不到相關文獻，請嘗試更換關鍵字或取消 Open Access 篩選。';
							if (isLoadMore && loadMoreBtn) loadMoreBtn.style.display = 'none';
						}
					} catch (error) {
						console.error('發生錯誤:', error);
						if(statusMsg) statusMsg.textContent = '連線至資料庫失敗，請稍後再試。';
					}
				}

				// 綁定事件
				if(searchBtn) searchBtn.addEventListener('click', () => searchPapers(false));
				if(searchInput) searchInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') searchPapers(false); });
				if(sortSelect) sortSelect.addEventListener('change', () => {
					// @ts-ignore
					if(searchInput.value.trim() !== '') searchPapers(false);
				});
				if(oaCheckbox) oaCheckbox.addEventListener('change', () => {
					// @ts-ignore
					if(searchInput.value.trim() !== '') searchPapers(false);
				});
				if(loadMoreBtn) loadMoreBtn.addEventListener('click', () => searchPapers(true));

				// 綁定複製按鈕事件 (使用事件委派)
				document.addEventListener('click', (e) => {
					// @ts-ignore
					if (e.target && e.target.classList.contains('btn-copy')) {
						e.preventDefault();
						// @ts-ignore
						const citation = decodeURIComponent(e.target.getAttribute('data-citation'));
						navigator.clipboard.writeText(citation).then(() => {
							// @ts-ignore
							const originalText = e.target.textContent;
							// @ts-ignore
							e.target.textContent = '✅ 已複製！';
							// @ts-ignore
							setTimeout(() => { e.target.textContent = originalText; }, 2000);
						});
					}
				});
			});
		</script>
	</body>
</html>
