---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`文獻導航 | ${SITE_TITLE}`} description="搜尋與整理學術文獻" />
		<style>
			main {
				width: 100%;
				max-width: 1000px;
				margin: 0 auto;
				padding: 40px 20px;
			}
			.page-title {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 10px;
				letter-spacing: -0.02em;
				color: #111;
			}
			.page-desc {
				color: #666;
				font-size: 1.1rem;
				margin-bottom: 40px;
				max-width: 600px;
				line-height: 1.6;
			}
			/* 搜尋區塊 */
			.search-box {
				display: flex;
				gap: 12px;
				margin-bottom: 20px;
				flex-wrap: wrap;
				align-items: center;
			}
			.search-input {
				flex: 1;
				min-width: 250px;
				padding: 16px 24px;
				font-size: 1.1rem;
				border: 1px solid #eaeaea;
				border-radius: 30px;
				background-color: #fcfcfc;
				transition: all 0.2s ease;
			}
			.search-input:focus {
				outline: none;
				border-color: #111;
				background-color: #fff;
			}
			.sort-select {
				padding: 16px 20px;
				font-size: 1rem;
				border: 1px solid #eaeaea;
				border-radius: 30px;
				background-color: #fcfcfc;
				color: #111;
				cursor: pointer;
				outline: none;
			}
			.search-btn {
				padding: 16px 32px;
				font-size: 1.1rem;
				font-weight: 600;
				color: #fff;
				background-color: #111;
				border: none;
				border-radius: 30px;
				cursor: pointer;
				transition: transform 0.2s ease, background-color 0.2s ease;
			}
			.search-btn:hover {
				background-color: #333;
				transform: translateY(-2px);
			}
			/* OA 開關 */
			.oa-toggle {
				display: flex;
				align-items: center;
				gap: 8px;
				font-size: 0.95rem;
				color: #555;
				cursor: pointer;
				margin-bottom: 30px;
				font-weight: 600;
			}
			.oa-toggle input {
				width: 18px;
				height: 18px;
				cursor: pointer;
			}
			/* 狀態提示 */
			#statusMsg {
				margin-bottom: 30px;
				color: #666;
				font-weight: 600;
			}
			/* 文獻卡片 */
			.paper-list {
				display: flex;
				flex-direction: column;
				gap: 24px;
			}
			.paper-card {
				background: #fdfdfd;
				border: 1px solid #eaeaea;
				border-radius: 20px;
				padding: 32px;
				position: relative;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.paper-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06);
			}
			.card-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 20px;
				margin-bottom: 20px;
			}
			.card-meta-top { flex: 1; }
			.stars {
				display: block;
				font-size: 0.9rem;
				font-weight: 700;
				color: #555;
				margin-bottom: 8px;
			}
			.paper-title {
				font-size: 1.5rem;
				margin: 0 0 12px 0;
				color: #111;
				line-height: 1.3;
				font-weight: 800;
			}
			.paper-subtitle {
				font-size: 0.95rem;
				color: #555;
				margin: 0;
				line-height: 1.6;
			}
			.oa-badge {
				display: inline-block;
				background: #ecfdf5;
				color: #059669;
				padding: 2px 8px;
				border-radius: 12px;
				font-size: 0.8rem;
				font-weight: 700;
				margin-left: 8px;
				vertical-align: middle;
			}
			/* 分數徽章 */
			.score-badge {
				background: #111;
				color: #fff;
				border-radius: 16px;
				padding: 12px 16px;
				text-align: center;
				min-width: 70px;
			}
			.score-number {
				display: block;
				font-size: 1.6rem;
				font-weight: 800;
				line-height: 1;
				margin-bottom: 4px;
			}
			.score-label {
				display: block;
				font-size: 0.75rem;
				opacity: 0.8;
			}
			/* 摘要與推薦 */
			.paper-abstract {
				font-size: 1rem;
				color: #444;
				line-height: 1.7;
				margin-bottom: 20px;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.recommend-box { margin-bottom: 24px; }
			.recommend-box h4 {
				margin: 0 0 10px 0;
				font-size: 1rem;
				color: #111;
				font-weight: 700;
			}
			.recommend-box ul {
				margin: 0;
				padding-left: 20px;
				color: #555;
				font-size: 0.95rem;
				line-height: 1.6;
			}
			/* 底部操作按鈕 */
			.action-btns {
				display: flex;
				gap: 12px;
				flex-wrap: wrap;
			}
			.btn-analyze, .btn-copy {
				background: #111;
				color: #fff;
				border: none;
				padding: 10px 24px;
				border-radius: 20px;
				font-weight: 600;
				cursor: pointer;
				text-decoration: none;
				transition: background 0.2s;
			}
			.btn-copy { background: #eab308; color: #111; }
			.btn-copy:hover { background: #ca8a04; }
			.btn-analyze:hover { background: #333; }
			.btn-open {
				background: #f5f5f5;
				color: #111;
				border: 1px solid #ddd;
				padding: 10px 24px;
				border-radius: 20px;
				font-weight: 600;
				cursor: pointer;
				text-decoration: none;
			}
			.btn-open:hover { background: #eaeaea; }
			
			/* ---------- 全新分頁系統樣式 ---------- */
			.pagination {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 8px;
				margin-top: 50px;
				flex-wrap: wrap;
			}
			.page-btn {
				background: #fff;
				color: #111;
				border: 1px solid #ddd;
				padding: 8px 16px;
				border-radius: 8px;
				cursor: pointer;
				font-weight: 600;
				font-size: 0.95rem;
				transition: all 0.2s;
			}
			.page-btn:hover:not(:disabled) {
				background: #f5f5f5;
				border-color: #bbb;
			}
			.page-btn.active {
				background: #111;
				color: #fff;
				border-color: #111;
			}
			.page-btn:disabled {
				opacity: 0.4;
				cursor: not-allowed;
				background: #fafafa;
			}
			.page-info {
				color: #888;
				font-size: 0.95rem;
				margin-left: 8px;
			}

			@media (max-width: 720px) {
				.search-box { flex-direction: column; align-items: stretch; }
				.card-header { flex-direction: column-reverse; }
				.score-badge { align-self: flex-start; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">文獻導航系統</h1>
			<p class="page-desc">輸入研究主題（建議使用英文），系統將透過 OpenAlex 資料庫搜尋文獻，並依照指定的條件進行排序與分析。</p>

			<div class="search-box">
				<input type="text" id="paperSearchInput" class="search-input" placeholder="例如: organic synthesis, complexometric titration..." />
				<select id="sortSelect" class="sort-select">
					<option value="relevance_score:desc">依照關聯度排序</option>
					<option value="cited_by_count:desc">依照引用次數排序</option>
					<option value="publication_year:desc">依照年份排序 (新至舊)</option>
				</select>
				<button id="searchBtn" class="search-btn">搜尋論文</button>
			</div>
			
			<label class="oa-toggle">
				<input type="checkbox" id="oaCheckbox" />
				<span>🟢 只顯示可免費下載的公開文獻 (Open Access)</span>
			</label>

			<div id="statusMsg"></div>
			<div id="paperResults" class="paper-list"></div>
			
			<div id="paginationContainer" class="pagination"></div>
		</main>
		<Footer />

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const searchInput = document.getElementById('paperSearchInput');
				const sortSelect = document.getElementById('sortSelect');
				const oaCheckbox = document.getElementById('oaCheckbox');
				const searchBtn = document.getElementById('searchBtn');
				const statusMsg = document.getElementById('statusMsg');
				const resultsContainer = document.getElementById('paperResults');
				const paginationContainer = document.getElementById('paginationContainer');

				// 儲存當前的搜尋狀態，避免切換頁面時條件跑掉
				let currentQuery = '';
				let currentSort = '';
				let currentIsOa = false;

				function reconstructAbstract(invertedIndex) {
					if (!invertedIndex) return '此篇文獻未提供摘要資料...';
					const words = [];
					for (const [word, positions] of Object.entries(invertedIndex)) {
						// @ts-ignore
						positions.forEach(pos => { words[pos] = word; });
					}
					return words.join(' ') + '...';
				}

				function generateRecommendations(paper, index, currentPage) {
					let reasons = [];
					if (currentPage === 1 && index < 3 && currentSort.includes('relevance')) reasons.push('主題高度相關');
					if (paper.publication_year <= 2018) reasons.push('較早期文獻，可作背景補充');
					if (paper.publication_year >= 2024) reasons.push('最新發表研究，掌握前沿動態');
					if (paper.cited_by_count > 500) reasons.push('高引用文獻，可能是領域代表作');
					if (paper.open_access?.is_oa) reasons.push('此為 Open Access 文獻，可直接免費取得全文');
					if (reasons.length === 0) reasons.push('符合當前搜尋條件之參考文獻');
					return reasons.map(r => `<li>${r}</li>`).join('');
				}

				function calculateDisplayScore(paper, overallIndex) {
					let baseScore = 95 - (overallIndex * 0.5); // 降低扣分幅度，讓後面頁面的分數緩慢下降
					if (paper.cited_by_count > 1000) baseScore += 5;
					return Math.min(100, Math.max(50, Math.round(baseScore)));
				}

				function generateCitation(paper) {
					let authors = 'Unknown Author';
					if (paper.authorships && paper.authorships.length > 0) {
						authors = paper.authorships.map((a:any) => a.author.display_name).join(', ');
					}
					const year = paper.publication_year || 'n.d.';
					const title = paper.title || 'Untitled';
					const journal = paper.primary_location?.source?.display_name || '';
					const doi = paper.doi ? ` ${paper.doi}` : '';
					return `${authors} (${year}). ${title}. ${journal ? journal + '.' : ''}${doi}`;
				}

				// 渲染分頁按鈕的邏輯
				function renderPagination(totalCount, currentPage) {
					if (!paginationContainer) return;
					paginationContainer.innerHTML = '';
					
					if (totalCount === 0) return;

					// 假設一頁 10 筆資料，計算總頁數 (為避免 API 負荷過重，限制最多只能看前 100 頁)
					const totalPages = Math.ceil(totalCount / 10);
					const maxAllowedPages = Math.min(totalPages, 100); 
					const maxVisibleBtns = 5; // 畫面上最多顯示幾個數字按鈕

					// 產生 [上一頁] 按鈕
					const prevBtn = document.createElement('button');
					prevBtn.className = 'page-btn';
					prevBtn.textContent = '← 上一頁';
					prevBtn.disabled = currentPage === 1;
					prevBtn.addEventListener('click', () => {
						window.scrollTo({ top: 0, behavior: 'smooth' });
						searchPapers(currentPage - 1);
					});
					paginationContainer.appendChild(prevBtn);

					// 計算數字按鈕的起始與結束範圍
					let startPage = Math.max(1, currentPage - Math.floor(maxVisibleBtns / 2));
					let endPage = Math.min(maxAllowedPages, startPage + maxVisibleBtns - 1);
					
					if (endPage - startPage + 1 < maxVisibleBtns) {
						startPage = Math.max(1, endPage - maxVisibleBtns + 1);
					}

					// 產生數字按鈕
					for (let i = startPage; i <= endPage; i++) {
						const pageBtn = document.createElement('button');
						pageBtn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
						pageBtn.textContent = i.toString();
						if (i !== currentPage) {
							pageBtn.addEventListener('click', () => {
								window.scrollTo({ top: 0, behavior: 'smooth' });
								searchPapers(i);
							});
						}
						paginationContainer.appendChild(pageBtn);
					}

					// 產生 [下一頁] 按鈕
					const nextBtn = document.createElement('button');
					nextBtn.className = 'page-btn';
					nextBtn.textContent = '下一頁 →';
					nextBtn.disabled = currentPage === maxAllowedPages;
					nextBtn.addEventListener('click', () => {
						window.scrollTo({ top: 0, behavior: 'smooth' });
						searchPapers(currentPage + 1);
					});
					paginationContainer.appendChild(nextBtn);

					// 如果總頁數很多，加上一個文字提示
					if (maxAllowedPages > endPage) {
						const infoSpan = document.createElement('span');
						infoSpan.className = 'page-info';
						infoSpan.textContent = `... 共 ${maxAllowedPages} 頁`;
						paginationContainer.appendChild(infoSpan);
					}
				}

				// 主要搜尋功能 (現在接收 pageNumber 參數)
				async function searchPapers(pageNumber = 1) {
					// 只有在第一頁搜尋時，才去抓取輸入框最新輸入的條件
					if (pageNumber === 1) {
						// @ts-ignore
						currentQuery = searchInput.value.trim();
						// @ts-ignore
						currentSort = sortSelect.value;
						// @ts-ignore
						currentIsOa = oaCheckbox.checked;
					}

					if (!currentQuery) return;

					if(statusMsg) statusMsg.textContent = '搜尋與分析中，請稍候...';
					if(resultsContainer) resultsContainer.innerHTML = '';
					if(paginationContainer) paginationContainer.innerHTML = '';

					try {
						let url = `https://api.openalex.org/works?search=${encodeURIComponent(currentQuery)}&per-page=10&page=${pageNumber}&sort=${currentSort}`;
						if (currentIsOa) {
							url += '&filter=is_oa:true';
						}

						const response = await fetch(url);
						const data = await response.json();

						if (data.results && data.results.length > 0) {
							// data.meta.count 會回傳符合條件的文獻「總數」
							const totalResults = data.meta.count;
							
							if(statusMsg) {
								statusMsg.innerHTML = `在 OpenAlex 中為您找到 <b>${totalResults.toLocaleString()}</b> 筆相關文獻（目前顯示第 ${pageNumber} 頁）：`;
							}
							
							data.results.forEach((paper: any, index: number) => {
								const card = document.createElement('div');
								card.className = 'paper-card';
								
								const title = paper.title || '無標題';
								const link = paper.doi || paper.id || '#';
								const year = paper.publication_year || '未知年份';
								const citedBy = paper.cited_by_count || 0;
								const journal = paper.primary_location?.source?.display_name || 'Unknown Journal';
								const isOa = paper.open_access?.is_oa;
								
								let authors = '未知作者';
								if (paper.authorships && paper.authorships.length > 0) {
									authors = paper.authorships.slice(0, 3).map((a:any) => a.author.display_name).join(', ');
									if (paper.authorships.length > 3) authors += ' 等人';
								}

								const abstractText = reconstructAbstract(paper.abstract_inverted_index);
								const recommendations = generateRecommendations(
