{
  "name": "kai-research-log",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "db:local:init": "wrangler d1 execute kai-research-db --local --file=./db/schema.sql",
    "db:remote:init": "wrangler d1 execute kai-research-db --remote --file=./db/schema.sql",
    "db:seed:generate": "node scripts/generate-d1-seed.mjs",
    "db:local:seed": "npm run db:seed:generate && wrangler d1 execute kai-research-db --local --file=./db/seed.sql",
    "db:remote:seed": "npm run db:seed:generate && wrangler d1 execute kai-research-db --remote --file=./db/seed.sql"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.3",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@cloudflare/workers-types": "^5.20260717.1",
    "wrangler": "^4.111.0"
  }
}
